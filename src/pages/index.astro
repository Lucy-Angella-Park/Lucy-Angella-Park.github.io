---
import Layout from '../layouts/Layout.astro';

const metrics = [
  { value: '6ms→1ms', label: 'Chat latency via WebSocket' },
  { value: '4', label: 'Shipped projects' },
  { value: '2.5yr', label: 'Analytical domain exp.' },
  { value: 'JPA+SQL', label: 'DB design & optimization' },
];

const skills = [
  { category: 'Backend', items: ['Java', 'Spring Boot', 'JPA', 'MyBatis'] },
  { category: 'Database', items: ['MySQL', 'MariaDB', 'SQL Optimization'] },
  { category: 'API & Integration', items: ['RESTful API', 'WebSocket', 'JSON', 'OpenAI API'] },
  { category: 'Infra & Tools', items: ['AWS', 'Docker', 'Git', 'Linux'] },
  { category: 'Frontend', items: ['JavaScript', 'React', 'Thymeleaf'] },
];

const projects = [
  {
    title: 'TuneMate',
    subtitle: 'Music Rating & Social Platform',
    period: 'Dec 2024',
    team: '2 people',
    stack: ['Java', 'Spring Boot', 'JPA', 'MySQL', 'React', 'Docker'],
    links: { github: 'https://github.com/potenday-tunemate/tunemate-be' },
    bullets: [
      'Designed RESTful API for album/review CRUD and user follow system',
      'Implemented genre-based sorting (latest / popularity) via JPQL',
      'Cross-functional collaboration across planning, design, backend, frontend via Slack',
    ],
  },
  {
    title: '6th Band Festival',
    subtitle: 'Festival Community Platform',
    period: 'Jul – Aug 2024',
    team: '6 people',
    stack: ['Java', 'Spring Boot', 'MyBatis', 'MariaDB', 'JavaScript', 'AWS'],
    links: {
      github: 'https://github.com/bamsanchaeg/6thBandFestival',
      live: 'https://festival.null-pointer-exception.com/',
      demo: 'https://www.youtube.com/watch?v=ZBPI1OCG3bc',
    },
    highlight: '6ms → 1ms',
    highlightLabel: 'chat latency',
    bullets: [
      'Cut real-time chat latency from 6ms → 1ms by replacing HTTP polling with WebSocket',
      'Integrated OpenAI API for automatic summarization of long comments',
      'Built 1:N group chat, voting system, photo gallery, and schedule management',
    ],
  },
  {
    title: 'Craft Studio Reservation',
    subtitle: 'Booking Management System',
    period: 'Jun 2024',
    team: '4 people',
    stack: ['Java', 'Spring Boot', 'MyBatis', 'MariaDB', 'Thymeleaf'],
    bullets: [
      'Designed weekday/weekend availability logic with capacity-based exception handling',
      'Prevented cascading data errors when studio records are deleted',
      'Eliminated page reloads via async RESTful API calls, improving UX',
    ],
  },
  {
    title: 'Community Board',
    subtitle: 'Full-Stack Board Application',
    period: 'May – Jun 2024',
    team: 'Solo',
    stack: ['Java', 'Spring Boot', 'MyBatis', 'MariaDB', 'Docker', 'Thymeleaf'],
    bullets: [
      'Built full-stack board: post/comment CRUD, likes, view count, authentication',
      'Containerized with Docker; gained end-to-end understanding of deploy flow',
    ],
  },
];

const experiences = [
  {
    company: 'PACESYSTEM',
    role: 'Software Engineer',
    period: 'Mar 2025 – Dec 2025',
    desc: 'Backend development with Java & Spring Boot in a full-time engineering role.',
  },
  {
    company: 'Joongangjeongbo IT Academy',
    role: 'Java Full-Stack Bootcamp',
    period: 'Mar 2024 – Aug 2024',
    desc: 'Cloud DevOps Frontend & Backend Java full-stack developer training camp.',
  },
  {
    company: 'Ipureun Environment',
    role: 'Analyst · Water Quality Analysis',
    period: 'Jul 2021 – Dec 2023',
    desc: 'GC (Gas Chromatography) instrument analysis; analytical precision in a data-driven lab.',
  },
];

const certifications = [
  {
    name: 'Engineer Information Processing',
    sub: '정보처리기사 필기합격',
    issuer: 'Human Resources Development Service of Korea',
    date: 'Jun 2024',
  },
];
---

<Layout>

  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--border)]"
       style="background: rgba(8,8,8,0.85); backdrop-filter: blur(12px);">
    <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
      <span class="text-sm font-medium text-[var(--text)]">Lucy Angella Park</span>
      <div class="flex gap-6 text-xs text-[var(--text-2)]">
        <a href="#projects" class="hover:text-[var(--text)] transition-colors">Projects</a>
        <a href="#experience" class="hover:text-[var(--text)] transition-colors">Experience</a>
        <a href="#contact" class="hover:text-[var(--text)] transition-colors">Contact</a>
      </div>
    </div>
  </nav>

  <main class="max-w-3xl mx-auto px-6 pt-32 pb-24 space-y-28">

    <!-- Hero -->
    <section class="space-y-8">
      <div class="space-y-3">
        <p class="text-xs tracking-[0.2em] uppercase text-[var(--muted)]">Software Engineer · Seoul</p>
        <h1 class="text-5xl font-bold tracking-tight leading-tight">
          Lucy<br/>Angella Park
        </h1>
        <p class="text-base text-[var(--text-2)] leading-relaxed max-w-lg pt-1">
          Backend engineer who debugs end-to-end, maps business requirements to
          database design, and ships systems that hold up in production.
          Career changer from biomedical science — analytical rigor, all the way down.
        </p>
      </div>

      <!-- Metrics -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {metrics.map((m) => (
          <div class="border border-[var(--border)] rounded-xl p-4 bg-[var(--bg-2)] space-y-1">
            <p class="text-xl font-semibold text-[var(--accent-2)]">{m.value}</p>
            <p class="text-xs text-[var(--muted)] leading-snug">{m.label}</p>
          </div>
        ))}
      </div>

      <!-- Links -->
      <div class="flex flex-wrap gap-3">
        <a href="https://github.com/Lucy-Angella-Park" target="_blank"
           class="flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--border)] text-sm text-[var(--text-2)] hover:border-[var(--accent)] hover:text-[var(--accent-2)] transition-all">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/lucy-angella-park" target="_blank"
           class="flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--border)] text-sm text-[var(--text-2)] hover:border-[var(--accent)] hover:text-[var(--accent-2)] transition-all">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href="mailto:thgml6951@gmail.com" id="contact"
           class="flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--border)] text-sm text-[var(--text-2)] hover:border-[var(--accent)] hover:text-[var(--accent-2)] transition-all">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Email
        </a>
      </div>
    </section>

    <!-- Skills -->
    <section class="space-y-6">
      <h2 class="text-xs tracking-[0.15em] uppercase text-[var(--muted)]">Skills</h2>
      <div class="space-y-4">
        {skills.map((group) => (
          <div class="flex gap-4 items-start">
            <span class="text-xs text-[var(--muted)] w-28 shrink-0 pt-0.5">{group.category}</span>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="text-xs px-3 py-1 rounded-full border border-[var(--border)] text-[var(--text-2)] bg-[var(--bg-2)]">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Projects -->
    <section class="space-y-6" id="projects">
      <h2 class="text-xs tracking-[0.15em] uppercase text-[var(--muted)]">Projects</h2>
      <div class="space-y-4">
        {projects.map((p) => (
          <div class="group relative rounded-2xl border border-[var(--border)] bg-[var(--bg-2)] p-6 space-y-4
                      hover:border-[var(--border-2)] hover:bg-[var(--surface)] transition-all duration-200">

            <!-- highlight badge -->
            {p.highlight && (
              <div class="absolute top-5 right-5 text-right">
                <span class="text-lg font-bold text-[var(--accent-2)]">{p.highlight}</span>
                <p class="text-xs text-[var(--muted)]">{p.highlightLabel}</p>
              </div>
            )}

            <div class="space-y-1">
              <div class="flex items-center gap-2 flex-wrap">
                <h3 class="font-semibold text-base">{p.title}</h3>
                <span class="text-xs text-[var(--muted)]">·</span>
                <span class="text-xs text-[var(--muted)]">{p.team}</span>
              </div>
              <p class="text-sm text-[var(--muted)]">{p.subtitle} · {p.period}</p>
            </div>

            <div class="flex flex-wrap gap-1.5">
              {p.stack.map((t) => (
                <span class="text-xs px-2.5 py-0.5 rounded-full bg-[var(--surface-2)] text-[var(--muted)] border border-[var(--border)]">{t}</span>
              ))}
            </div>

            <ul class="space-y-2">
              {p.bullets.map((b) => (
                <li class="text-sm text-[var(--text-2)] flex gap-2.5 leading-relaxed">
                  <span class="text-[var(--accent)] shrink-0 mt-0.5">›</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            {(p.links?.github || p.links?.live || p.links?.demo) && (
              <div class="flex gap-4 pt-1">
                {p.links?.github && (
                  <a href={p.links.github} target="_blank"
                     class="text-xs text-[var(--muted)] hover:text-[var(--accent-2)] transition-colors flex items-center gap-1">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                    </svg>
                    Code
                  </a>
                )}
                {p.links?.live && (
                  <a href={p.links.live} target="_blank"
                     class="text-xs text-[var(--muted)] hover:text-[var(--accent-2)] transition-colors flex items-center gap-1">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    Live
                  </a>
                )}
                {p.links?.demo && (
                  <a href={p.links.demo} target="_blank"
                     class="text-xs text-[var(--muted)] hover:text-[var(--accent-2)] transition-colors flex items-center gap-1">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <polygon points="5 3 19 12 5 21 5 3"/>
                    </svg>
                    Demo
                  </a>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Experience -->
    <section class="space-y-6" id="experience">
      <h2 class="text-xs tracking-[0.15em] uppercase text-[var(--muted)]">Experience</h2>
      <div class="space-y-0">
        {experiences.map((e, i) => (
          <div class={`relative pl-6 pb-8 ${i < experiences.length - 1 ? 'border-l border-[var(--border)]' : ''}`}>
            <div class="absolute left-0 top-1.5 -translate-x-1/2 w-2 h-2 rounded-full bg-[var(--border-2)] border border-[var(--border)]"/>
            <div class="space-y-1">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <p class="font-medium text-sm">{e.company}</p>
                <span class="text-xs text-[var(--muted)] shrink-0">{e.period}</span>
              </div>
              <p class="text-xs text-[var(--accent-2)]">{e.role}</p>
              <p class="text-xs text-[var(--muted)] leading-relaxed pt-0.5">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Certifications -->
    <section class="space-y-6">
      <h2 class="text-xs tracking-[0.15em] uppercase text-[var(--muted)]">Certifications</h2>
      {certifications.map((c) => (
        <div class="flex items-center justify-between py-3 border-b border-[var(--border)]">
          <div class="space-y-0.5">
            <p class="text-sm font-medium">{c.name}</p>
            <p class="text-xs text-[var(--muted)]">{c.sub} · {c.issuer}</p>
          </div>
          <span class="text-xs text-[var(--muted)] shrink-0">{c.date}</span>
        </div>
      ))}
    </section>

    <!-- Footer -->
    <footer class="flex items-center justify-between text-xs text-[var(--muted)] pt-4 border-t border-[var(--border)]">
      <span>Lucy Angella Park</span>
      <span>Built with Astro + Tailwind</span>
    </footer>

  </main>
</Layout>
