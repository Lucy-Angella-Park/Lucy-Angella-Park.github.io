---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lucy Angella Park — Software Engineer',
  description = 'Backend Software Engineer specializing in Java/Spring Boot. Career changer with a passion for building robust, user-centered systems.',
} = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Lucy Angella Park',
  jobTitle: 'Software Engineer',
  url: 'https://lucy-angella-park.github.io',
  sameAs: [
    'https://github.com/Lucy-Angella-Park',
    'https://www.linkedin.com/in/lucy-angella-park',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
